{
  "$schema": "项目页面语义色板（light / dark）。实现映射见 design-system/TOKENS.md 与 src/styles/theme/page-semantic.scss",
  "typography": {
    "heading": "DM Sans",
    "body": "Rubik"
  },
  "brand": {
    "accent": "#FF8400",
    "accentHover": "#C2410C",
    "accentSoftLight": "#FFF7ED",
    "accentBorderLight": "#FED7AA",
    "accentSoftDark": "rgb(255 132 0 / 12%)",
    "accentBorderDark": "rgb(255 132 0 / 28%)"
  },
  "ep": {
    "primaryDefault": "#2563eb"
  },
  "light": {
    "bg": "#FFFFFF",
    "surface": "#FAFAFA",
    "border": "#E5E5E5",
    "text": "#141414",
    "textMuted": "#666666",
    "textDim": "#999999",
    "cta": "#141414",
    "hover": "rgb(0 0 0 / 4%)"
  },
  "dark": {
    "bg": "#141414",
    "surface": "#1A1A1A",
    "border": "#2A2A2A",
    "text": "#FAFAFA",
    "textMuted": "#A3A3A3",
    "textDim": "#737373",
    "cta": "#FAFAFA",
    "hover": "rgb(255 255 255 / 6%)"
  },
  "theme": {
    "modeDefault": "light",
    "modeAcceptance": ["light", "dark"]
  }
}
