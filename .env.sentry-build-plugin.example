# Sentry 构建期 Source Map 上传（复制为 .env.sentry-build-plugin 并填写，勿提交仓库）
# 也可在 CI 或 shell 中 export 同名变量；与 @sentry/vite-plugin 官方约定一致

SENTRY_UPLOAD_SOURCEMAPS=true
# Organization Auth Token（前缀 sntrys_，UI 固定 scope：org:ci）
# 用途：Source Map 上传、Release（npm run build）
# Issue 闭环：见 .env.sentry-resolve.example（User Token + event:write）
SENTRY_AUTH_TOKEN=<token>
SENTRY_ORG=<org>
SENTRY_URL=https://<sentry-host>
